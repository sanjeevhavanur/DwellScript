<style>
.terms-shell {
    max-width: 820px;
    margin: 0 auto;
    padding: 48px 24px 80px;
}

.terms-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
}

.terms-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
    text-decoration: none;
}

.terms-logo-mark {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--ds-warm-500), var(--ds-warm-600));
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 800;
    color: #fff;
}

.terms-logo-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
}

.terms-logo-text span { color: var(--ds-warm-500); }

.terms-title {
    font-size: 28px;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 8px;
}

.terms-meta {
    font-size: 13px;
    color: var(--text-secondary);
}

.terms-body h2 {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 36px;
    margin-bottom: 12px;
}

.terms-body h3 {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 20px;
    margin-bottom: 8px;
}

.terms-body p, .terms-body li {
    font-size: 14px;
    line-height: 1.75;
    color: var(--text-secondary);
}

.terms-body ul {
    padding-left: 20px;
    margin-bottom: 12px;
}

.terms-body li { margin-bottom: 4px; }

.terms-highlight {
    background: rgba(234, 88, 12, 0.07);
    border-left: 3px solid var(--ds-warm-500);
    padding: 12px 16px;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: 16px 0;
}

.terms-highlight p {
    margin: 0;
    font-weight: 600;
    color: var(--text-primary) !important;
}

.terms-toc {
    background: var(--bg-surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 20px 24px;
    margin-bottom: 40px;
}

.terms-toc-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: .05em;
}

.terms-toc ol {
    margin: 0;
    padding-left: 18px;
}

.terms-toc li {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 4px;
}

.terms-toc a {
    color: var(--ds-navy-500);
    text-decoration: none;
}

.terms-toc a:hover { text-decoration: underline; }

@@media (prefers-color-scheme: dark) {
    .terms-toc a { color: var(--ds-warm-400); }
}
</style>

