@{
    ViewData["Title"]           = "Pricing";
    ViewData["MetaTitle"]       = "DwellScript Pricing — Free, Starter & Pro Plans";
    ViewData["MetaDescription"] = "DwellScript starts free. Upgrade to Starter ($9/mo) or Pro ($19/mo) for unlimited AI-generated rental listings, Vacancy Analyzer, and Persona Targeting.";
    ViewData["Canonical"]       = "https://dwellscript.com/Pricing";
    Layout = "_AuthLayout";
}

<style>
/* ── Shared layout ───────────────────────────────── */
.lp-body { font-family: 'Inter', sans-serif; background: var(--bg-page); color: var(--text-primary); }
.lp-container { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
.lp-section { padding: 72px 24px; }

/* ── Navbar ──────────────────────────────────────── */
.lp-btn-primary {
    padding: 14px 28px;
    background: linear-gradient(135deg, var(--ds-warm-600), var(--ds-warm-500));
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 6px 20px rgba(234,88,12,.35);
    transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.lp-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 28px rgba(234,88,12,.45); color: #fff; }
.btn-ds-ghost {
    padding: 9px 20px;
    background: transparent;
    color: rgba(255,255,255,.8);
    border: 1.5px solid rgba(255,255,255,.25);
    border-radius: 12px;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all .2s ease;
}
.btn-ds-ghost:hover { background: rgba(255,255,255,.08); color: #fff; }

/* ── Hero ────────────────────────────────────────── */
.pricing-hero {
    background: var(--ds-navy-900);
    background-image:
        radial-gradient(ellipse at 20% 60%, rgba(37,99,235,.2) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 20%, rgba(249,115,22,.14) 0%, transparent 50%);
    padding: 72px 24px 80px;
    text-align: center;
}
.pricing-hero-title {
    font-size: clamp(28px, 4.5vw, 48px);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 16px;
    letter-spacing: -.02em;
}
.pricing-hero-sub {
    font-size: 16px;
    color: rgba(255,255,255,.6);
    max-width: 480px;
    margin: 0 auto 0;
    line-height: 1.7;
}
.lp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 999px;
    padding: 5px 16px;
    font-size: 12.5px;
    font-weight: 600;
    color: rgba(255,255,255,.8);
    margin-bottom: 22px;
    background: rgba(255,255,255,.05);
}

/* ── Toggle ──────────────────────────────────────── */
.billing-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 40px 0 0;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,.65);
}
.toggle-switch {
    width: 44px; height: 24px;
    background: #cbd5e1;
    border-radius: 999px;
    cursor: pointer;
    position: relative;
    transition: background .2s;
    border: none;
    appearance: none;
    flex-shrink: 0;
}
.toggle-switch:checked { background: var(--ds-warm-500); }
.toggle-switch::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #fff;
    transition: left .2s;
    box-shadow: 0 1px 3px rgba(0,0,0,.2);
}
.toggle-switch:checked::after { left: 23px; }
.save-badge {
    background: rgba(34,197,94,.15);
    color: #4ade80;
    border: 1px solid rgba(74,222,128,.25);
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
}

/* ── Pricing cards ───────────────────────────────── */
.pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    max-width: 900px;
    margin: 52px auto 0;
}
.price-card {
    background: var(--bg-surface);
    border: 2px solid var(--border);
    border-radius: 24px;
    padding: 30px 28px;
    box-shadow: var(--shadow-sm);
    transition: all .2s ease;
    display: flex;
    flex-direction: column;
}
.price-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
.price-card.featured {
    border-color: var(--ds-warm-500);
    background: linear-gradient(160deg, #fff 60%, var(--ds-warm-50));
}
.price-card.pro { border-color: var(--ds-navy-400); }

.price-card-header { margin-bottom: 20px; }
.price-tier-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.price-tier-name { font-size: 17px; font-weight: 800; color: var(--text-primary); }
.tier-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
}
.tier-badge.popular { background: var(--ds-warm-100); color: var(--ds-warm-700); }
.tier-badge.pro { background: var(--ds-navy-100); color: var(--ds-navy-700); }

.price-amount {
    font-size: 42px;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 2px;
}
.price-amount sup { font-size: 20px; font-weight: 600; }
.price-amount .original {
    font-size: 18px;
    font-weight: 500;
    color: var(--text-tertiary);
    text-decoration: line-through;
    margin-left: 6px;
}
.price-period { font-size: 13px; color: var(--text-tertiary); margin-top: 4px; }

.price-features {
    list-style: none;
    padding: 0;
    margin: 20px 0 28px;
    display: flex;
    flex-direction: column;
    gap: 11px;
    flex: 1;
}
.price-feature {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 13.5px;
    color: var(--text-secondary);
}
.price-feature i { font-size: 14px; color: var(--ds-success); flex-shrink: 0; }
.price-feature.no i { color: var(--text-tertiary); }
.price-feature.no { color: var(--text-tertiary); }
.price-feature strong { color: var(--text-primary); font-weight: 600; }

.price-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 20px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: all .2s ease;
    cursor: pointer;
    border: none;
    width: 100%;
}
.price-cta.ghost {
    background: transparent;
    border: 1.5px solid var(--border-strong);
    color: var(--text-primary);
}
.price-cta.ghost:hover { background: var(--bg-surface-2); }
.price-cta.accent {
    background: linear-gradient(135deg, var(--ds-warm-600), var(--ds-warm-500));
    color: #fff;
    box-shadow: 0 4px 16px rgba(234,88,12,.3);
}
.price-cta.accent:hover { transform: translateY(-1px); box-shadow: 0 6px 22px rgba(234,88,12,.4); color: #fff; }
.price-cta.navy {
    background: var(--ds-navy-800);
    color: #fff;
    box-shadow: 0 4px 16px rgba(15,31,61,.25);
}
.price-cta.navy:hover { background: var(--ds-navy-700); color: #fff; }

/* ── Comparison table ────────────────────────────── */
.compare-section { padding: 72px 24px; background: var(--bg-surface-2); }
.compare-table {
    width: 100%;
    max-width: 860px;
    margin: 40px auto 0;
    border-collapse: collapse;
    font-size: 14px;
}
.compare-table th {
    padding: 12px 16px;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    border-bottom: 2px solid var(--border);
}
.compare-table th:first-child { text-align: left; color: var(--text-tertiary); font-weight: 500; }
.compare-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
    text-align: center;
}
.compare-table td:first-child { text-align: left; color: var(--text-primary); font-weight: 500; }
.compare-table tr:last-child td { border-bottom: none; }
.compare-table tr:hover td { background: var(--bg-surface); }
.compare-check { color: var(--ds-success); font-size: 16px; }
.compare-cross { color: var(--text-tertiary); font-size: 16px; }
.col-highlighted { background: rgba(249,115,22,.04); }

/* ── FAQ ─────────────────────────────────────────── */
.faq-section { padding: 72px 24px; }
.faq-grid { max-width: 720px; margin: 40px auto 0; display: flex; flex-direction: column; gap: 0; }
.faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
.faq-item:first-child { border-top: 1px solid var(--border); }
.faq-q { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 10px; }
.faq-a { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }

/* ── CTA ─────────────────────────────────────────── */
.lp-cta-section {
    background: var(--ds-navy-900);
    background-image: radial-gradient(ellipse at 30% 50%, rgba(249,115,22,.15) 0%, transparent 55%),
                      radial-gradient(ellipse at 80% 30%, rgba(37,99,235,.2) 0%, transparent 50%);
    padding: 80px 24px;
    text-align: center;
}

/* ── Footer ──────────────────────────────────────── */
.lp-footer { background: var(--ds-navy-900); border-top: 1px solid rgba(255,255,255,.08); padding: 32px 24px; text-align: center; }
.lp-footer-links { display: flex; justify-content: center; gap: 24px; margin-bottom: 12px; flex-wrap: wrap; }
.lp-footer-links a { font-size: 13px; color: rgba(255,255,255,.45); text-decoration: none; }
.lp-footer-links a:hover { color: rgba(255,255,255,.8); }
.lp-footer-text { font-size: 13px; color: rgba(255,255,255,.35); }

@@media (max-width: 640px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .compare-table { font-size: 12px; }
    .compare-table th, .compare-table td { padding: 10px 8px; }
}
</style>

<div class="lp-body">

    <!-- ── Navbar ──────────────────────────────────────── -->
    <nav style="position:sticky;top:0;z-index:200;background:rgba(15,31,61,.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.07);padding:0 24px;">
        <div style="max-width:1080px;margin:0 auto;height:60px;display:flex;align-items:center;justify-content:space-between;">
            <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
                <img src="~/logo/DwellScriptLogo.png" alt="DwellScript" style="height:38px;width:auto;" />
            </a>
            <div style="display:flex;align-items:center;gap:16px;">
                <a href="/#features" style="font-size:13.5px;font-weight:500;color:rgba(255,255,255,.6);text-decoration:none;">Features</a>
                <a href="/Pricing" style="font-size:13.5px;font-weight:500;color:#fff;text-decoration:none;">Pricing</a>
                <a href="/Auth/Login" class="lp-btn-primary" style="padding:9px 20px;font-size:13.5px;">Get Started Free</a>
            </div>
        </div>
    </nav>

    <!-- ── Hero ────────────────────────────────────────── -->
    <section class="pricing-hero">
        <div class="lp-container">
            <div class="lp-eyebrow">
                <i class="bi bi-tag-fill" style="color:var(--ds-warm-400)"></i>
                Simple, transparent pricing
            </div>
            <h1 class="pricing-hero-title">
                Start free.<br>Upgrade when you need more.
            </h1>
            <p class="pricing-hero-sub">
                No credit card required. No hidden fees. Cancel anytime.
            </p>
        </div>
    </section>

    <!-- ── Billing Toggle ───────────────────────────────── -->
    <div style="display:flex;justify-content:center;padding:32px 24px 0;">
        <div style="display:inline-flex;align-items:center;gap:12px;background:var(--bg-surface);border:1.5px solid var(--border);border-radius:999px;padding:8px 20px;box-shadow:var(--shadow-sm);">
            <span style="font-size:14px;font-weight:600;color:var(--text-secondary)" id="labelMonthly">Monthly</span>
            <input type="checkbox" class="toggle-switch" id="annualToggle" style="background:var(--border-strong);" />
            <span style="font-size:14px;font-weight:600;color:var(--text-secondary)">Annual</span>
            <span class="save-badge" style="background:rgba(34,197,94,.12);color:#16a34a;border:1px solid rgba(34,197,94,.25);padding:3px 10px;border-radius:999px;font-size:12px;font-weight:700;">Save 20%</span>
        </div>
    </div>

    <!-- ── Pricing Cards ────────────────────────────────── -->
    <section style="padding: 0 24px; margin-top: 24px; position: relative; z-index: 10;">
        <div class="pricing-grid">

            <!-- Free -->
            <div class="price-card">
                <div class="price-card-header">
                    <div class="price-tier-row">
                        <div class="price-tier-name">Free</div>
                    </div>
                    <div class="price-amount"><sup>$</sup>0</div>
                    <div class="price-period">forever</div>
                </div>
                <ul class="price-features">
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>1 property</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>3 generations / month</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>LTR + STR + Social copy</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Generation history</li>
                    <li class="price-feature no"><i class="bi bi-x-circle"></i>Section refinement</li>
                    <li class="price-feature no"><i class="bi bi-x-circle"></i>Vacancy Analyzer</li>
                    <li class="price-feature no"><i class="bi bi-x-circle"></i>Persona Targeting</li>
                </ul>
                <a href="/Auth/Login" class="price-cta ghost">Get Started Free</a>
            </div>

            <!-- Starter -->
            <div class="price-card featured">
                <div class="price-card-header">
                    <div class="price-tier-row">
                        <div class="price-tier-name">Starter</div>
                        <span class="tier-badge popular"><i class="bi bi-fire"></i>Popular</span>
                    </div>
                    <div class="price-amount">
                        <sup>$</sup><span id="starterPrice">9</span>
                        <span class="original" id="starterOriginal" style="display:none">$9</span>
                    </div>
                    <div class="price-period" id="starterPeriod">per month, billed monthly</div>
                </div>
                <ul class="price-features">
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Up to 5 properties</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>30 generations / month</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>LTR + STR + Social copy</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i><strong>Section refinement</strong></li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Generation history</li>
                    <li class="price-feature no"><i class="bi bi-x-circle"></i>Vacancy Analyzer</li>
                    <li class="price-feature no"><i class="bi bi-x-circle"></i>Persona Targeting</li>
                </ul>
                <a href="/Auth/Login" class="price-cta accent"><i class="bi bi-stars"></i>Get Starter</a>
            </div>

            <!-- Pro -->
            <div class="price-card pro">
                <div class="price-card-header">
                    <div class="price-tier-row">
                        <div class="price-tier-name">Pro</div>
                        <span class="tier-badge pro"><i class="bi bi-stars"></i>Pro</span>
                    </div>
                    <div class="price-amount">
                        <sup>$</sup><span id="proPrice">19</span>
                        <span class="original" id="proOriginal" style="display:none">$19</span>
                    </div>
                    <div class="price-period" id="proPeriod">per month, billed monthly</div>
                </div>
                <ul class="price-features">
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Unlimited properties</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Unlimited generations</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>LTR + STR + Social copy</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Section refinement</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Generation history</li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i><strong>Vacancy Analyzer</strong></li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i><strong>Persona Targeting</strong></li>
                    <li class="price-feature"><i class="bi bi-check-circle-fill"></i>Priority support</li>
                </ul>
                <a href="/Auth/Login" class="price-cta navy"><i class="bi bi-stars"></i>Get Pro</a>
            </div>

        </div>
    </section>

    <!-- ── Comparison Table ─────────────────────────────── -->
    <section class="compare-section">
        <div class="lp-container" style="text-align:center">
            <div style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ds-warm-600);margin-bottom:10px">Compare plans</div>
            <h2 style="font-size:clamp(22px,3vw,34px);font-weight:800;color:var(--text-primary);margin:0">Everything you get, side by side.</h2>
            <table class="compare-table">
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th>Free</th>
                        <th class="col-highlighted">Starter</th>
                        <th>Pro</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Properties</td>
                        <td>1</td>
                        <td class="col-highlighted">Up to 5</td>
                        <td>Unlimited</td>
                    </tr>
                    <tr>
                        <td>Generations / month</td>
                        <td>3</td>
                        <td class="col-highlighted">30</td>
                        <td>Unlimited</td>
                    </tr>
                    <tr>
                        <td>LTR + STR + Social copy</td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td class="col-highlighted"><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Listing headlines</td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td class="col-highlighted"><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Generation history</td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td class="col-highlighted"><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Fair Housing compliance filter</td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td class="col-highlighted"><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Section refinement</td>
                        <td><i class="bi bi-x-circle compare-cross"></i></td>
                        <td class="col-highlighted"><i class="bi bi-check-circle-fill compare-check"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Vacancy Analyzer</td>
                        <td><i class="bi bi-x-circle compare-cross"></i></td>
                        <td class="col-highlighted"><i class="bi bi-x-circle compare-cross"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Persona Targeting</td>
                        <td><i class="bi bi-x-circle compare-cross"></i></td>
                        <td class="col-highlighted"><i class="bi bi-x-circle compare-cross"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                    <tr>
                        <td>Priority support</td>
                        <td><i class="bi bi-x-circle compare-cross"></i></td>
                        <td class="col-highlighted"><i class="bi bi-x-circle compare-cross"></i></td>
                        <td><i class="bi bi-check-circle-fill compare-check"></i></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- ── FAQ ──────────────────────────────────────────── -->
    <section class="faq-section">
        <div class="lp-container" style="text-align:center">
            <div style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ds-warm-600);margin-bottom:10px">FAQ</div>
            <h2 style="font-size:clamp(22px,3vw,34px);font-weight:800;color:var(--text-primary);margin:0">Common questions.</h2>
            <div class="faq-grid" style="text-align:left">
                <div class="faq-item">
                    <div class="faq-q">Do I need a credit card to start?</div>
                    <div class="faq-a">No. The Free plan requires no credit card. You only enter payment information when you choose to upgrade to Starter or Pro.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">What counts as a "generation"?</div>
                    <div class="faq-a">Each time you generate listing copy for a property — LTR, STR, social caption, and headline all in one click — that counts as one generation. Re-generating or using section refinement does not count against your quota.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">Can I cancel anytime?</div>
                    <div class="faq-a">Yes. Cancel anytime from your billing settings. You keep access until the end of your current billing period, and you will never be charged again.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">What is the Vacancy Analyzer?</div>
                    <div class="faq-a">The Vacancy Analyzer reviews your listing and gives AI-powered feedback on why a unit might be sitting vacant — covering pricing, copy quality, and market positioning. It is a Pro-only feature.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">What is Persona Targeting?</div>
                    <div class="faq-a">Persona Targeting rewrites your long-term rental copy to speak directly to a specific renter profile — remote workers, pet owners, commuters, students, and more. Available on Pro.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">Is the copy Fair Housing compliant?</div>
                    <div class="faq-a">Yes. Every generation is automatically scanned by a Fair Housing compliance filter that flags and removes language that could violate federal housing regulations. This is included on all plans.</div>
                </div>
                <div class="faq-item">
                    <div class="faq-q">Do you offer annual billing?</div>
                    <div class="faq-a">Yes. Switch to annual billing and save 20% compared to monthly. You can toggle between monthly and annual at any time from your billing settings.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Final CTA ─────────────────────────────────────── -->
    <section class="lp-cta-section">
        <div class="lp-container">
            <div class="lp-eyebrow" style="margin:0 auto 20px">
                <i class="bi bi-lock-fill" style="color:var(--ds-warm-400)"></i>No password required
            </div>
            <h2 style="font-size:clamp(26px,4vw,42px);font-weight:800;color:#fff;margin-bottom:14px;line-height:1.2">
                Your next vacancy fills faster.<br>Start writing in seconds.
            </h2>
            <p style="font-size:16px;color:rgba(255,255,255,.55);margin-bottom:36px;max-width:460px;margin-left:auto;margin-right:auto">
                Sign in with your email or Google. No password needed, ever.
            </p>
            <a href="/Auth/Login" class="lp-btn-primary" style="font-size:16px;padding:16px 36px">
                <i class="bi bi-stars"></i>Get Started — It's Free
            </a>
        </div>
    </section>

    <!-- ── Footer ────────────────────────────────────────── -->
    <footer class="lp-footer">
        <div class="lp-footer-links">
            <a href="/Pricing">Pricing</a>
            <a href="/Home/Privacy">Privacy Policy</a>
            <a href="/Home/Terms">Terms of Service</a>
            <a href="/Auth/Login">Sign In</a>
        </div>
        <div class="lp-footer-text">&copy; @DateTime.UtcNow.Year DwellScript. All rights reserved.</div>
    </footer>

</div>

@section Scripts {
<script>
    var annualToggle = document.getElementById('annualToggle');
    var starterPrice = document.getElementById('starterPrice');
    var starterPeriod = document.getElementById('starterPeriod');
    var starterOriginal = document.getElementById('starterOriginal');
    var proPrice = document.getElementById('proPrice');
    var proPeriod = document.getElementById('proPeriod');
    var proOriginal = document.getElementById('proOriginal');

    annualToggle.addEventListener('change', function () {
        if (this.checked) {
            starterPrice.textContent = '7';
            starterOriginal.textContent = '$9';
            starterOriginal.style.display = '';
            starterPeriod.textContent = 'per month, billed annually ($86/yr)';
            proPrice.textContent = '15';
            proOriginal.textContent = '$19';
            proOriginal.style.display = '';
            proPeriod.textContent = 'per month, billed annually ($182/yr)';
        } else {
            starterPrice.textContent = '9';
            starterOriginal.style.display = 'none';
            starterPeriod.textContent = 'per month, billed monthly';
            proPrice.textContent = '19';
            proOriginal.style.display = 'none';
            proPeriod.textContent = 'per month, billed monthly';
        }
    });
</script>
}

