@{
    ViewData["Title"] = "Sign in";
    ViewData["HideNav"] = true;
    var error = Context.Request.Query["error"].ToString();
}

<div class="auth-card px-3">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <h4 class="fw-bold text-primary mb-1">
                    <i class="bi bi-house-heart-fill me-1"></i>DwellScript
                </h4>
                <p class="text-muted mb-0">Sign in to your account</p>
            </div>

            @if (error == "expired")
            {
                <div class="alert alert-warning py-2 small">
                    <i class="bi bi-clock me-1"></i>That link has expired. Request a new one below.
                </div>
            }
            else if (error == "invalid")
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-1"></i>Invalid login link. Please try again.
                </div>
            }
            else if (error == "google")
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-circle me-1"></i>Google sign-in failed. Please try again.
                </div>
            }

            @* Magic Link Form *@
            <form id="magicLinkForm" novalidate>
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="email" class="form-label fw-medium">Email address</label>
                    <input type="email" class="form-control form-control-lg" id="email" name="email"
                           placeholder="you@example.com" required autocomplete="email" />
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg" id="magicLinkBtn">
                        <span class="btn-text">Send magic link</span>
                        <span class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
                    </button>
                </div>
            </form>

            <div class="divider-text my-4">or</div>

            @* Google OAuth *@
            <div class="d-grid">
                <a href="/Auth/GoogleLogin" class="btn btn-outline-secondary btn-lg">
                    <svg class="me-2" style="width:18px;height:18px;vertical-align:-3px" viewBox="0 0 48 48">
                        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                    </svg>
                    Continue with Google
                </a>
            </div>

            <p class="text-center text-muted small mt-4 mb-0">
                No password needed. We'll email you a secure link.
            </p>

        </div>
    </div>
</div>

@section Scripts {
<script>
    $('#magicLinkForm').on('submit', function (e) {
        e.preventDefault();

        var email = $('#email').val().trim();
        if (!email) return;

        var $btn = $('#magicLinkBtn');
        $btn.prop('disabled', true);
        $btn.find('.btn-text').text('Sending...');
        $btn.find('.spinner-border').removeClass('d-none');

        $.ajax({
            url: '/Auth/SendMagicLink',
            method: 'POST',
            data: {
                email: email,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            success: function (res) {
                toastr.success(res.message);
                $('#magicLinkForm')[0].reset();
            },
            error: function (xhr) {
                var msg = xhr.responseJSON?.message ?? 'Something went wrong. Please try again.';
                toastr.error(msg);
            },
            complete: function () {
                $btn.prop('disabled', false);
                $btn.find('.btn-text').text('Send magic link');
                $btn.find('.spinner-border').addClass('d-none');
            }
        });
    });
</script>
}
