<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DwellScript</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/logo/DwellScriptLogo.png" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    var currentAction     = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
    var userEmail   = User.Identity?.Name ?? "";
    var userInitial = userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "?";
    var tier        = ViewData["Tier"]?.ToString() ?? "Free";
    var quotaUsed   = ViewData["QuotaUsed"] as int? ?? 0;
    var quotaMax    = ViewData["QuotaMax"] as int? ?? 3;
    var quotaPct    = quotaMax > 0 ? Math.Min(100, (int)((quotaUsed / (double)quotaMax) * 100)) : 0;
    var quotaWarning = quotaPct >= 66;
}

<div class="ds-shell">

    <!-- ── Sidebar ────────────────────────────────── -->
    <aside class="ds-sidebar">

        <a href="/Property" class="ds-sidebar-logo">
            <img src="~/logo/DwellScriptLogo.png" alt="DwellScript" style="height:36px;width:auto;" />
        </a>

        <nav class="ds-nav">
            <div class="ds-nav-label">Menu</div>

            <a href="/Property" class="ds-nav-item @(currentController == "property" ? "active" : "")">
                <i class="bi bi-buildings"></i>Properties
            </a>
            <a href="/Billing" class="ds-nav-item @(currentController == "billing" ? "active" : "")">
                <i class="bi bi-credit-card"></i>Billing
            </a>
        </nav>

        <div class="ds-sidebar-bottom">
            <div class="ds-quota-block">
                <div class="ds-quota-label">
                    <span>Generations</span>
                    <span>@quotaUsed / @quotaMax</span>
                </div>
                <div class="ds-quota-bar">
                    <div class="ds-quota-fill @(quotaWarning ? "warning" : "")" style="width:@quotaPct%"></div>
                </div>
            </div>

            @if (tier == "Free" || tier == "Starter")
            {
                <a href="/Billing" class="ds-upgrade-btn">
                    <i class="bi bi-stars"></i>Upgrade to Pro
                </a>
            }

            <div class="ds-user-row">
                <div class="ds-avatar">@userInitial</div>
                <span class="ds-user-name">@userEmail</span>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="ms-auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="background:none;border:none;padding:0;color:rgba(255,255,255,.4);cursor:pointer;font-size:14px;" title="Sign out">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <!-- ── Main ───────────────────────────────────── -->
    <div class="ds-main">

        <!-- Topbar -->
        <header class="ds-topbar">
            <span class="ds-topbar-title">@(ViewData["Title"] ?? "DwellScript")</span>
            <div class="ds-topbar-actions">
                <button class="ds-icon-btn" id="themeToggle" title="Toggle dark mode">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
                <span class="ds-pill ds-pill-@tier.ToLower()">@tier</span>
            </div>
        </header>

        @await RenderSectionAsync("PageTabs", required: false)

        <!-- Content -->
        <div class="ds-content">
            @RenderBody()
        </div>

    </div>
</div>

<!-- Copied tooltip -->
<div id="copiedTooltip"></div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.js"></script>
<script>
    toastr.options = { positionClass: 'toast-top-right', timeOut: 4000, closeButton: true, progressBar: true, newestOnTop: true };

    // Dark mode
    (function () {
        var saved = localStorage.getItem('ds-theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.getElementById('themeIcon').className = 'bi bi-sun-fill';
        }
    })();

    $('#themeToggle').on('click', function () {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (isDark) {
            document.documentElement.removeAttribute('data-theme');
            document.getElementById('themeIcon').className = 'bi bi-moon-stars-fill';
            localStorage.setItem('ds-theme', 'light');
        } else {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.getElementById('themeIcon').className = 'bi bi-sun-fill';
            localStorage.setItem('ds-theme', 'dark');
        }
    });

    // Copy tooltip
    function showCopied(label) {
        var el = document.getElementById('copiedTooltip');
        el.textContent = '✓ ' + label + ' copied';
        el.classList.add('show');
        setTimeout(function () { el.classList.remove('show'); }, 2200);
    }

    // CSRF helper
    function csrfToken() {
        return $('input[name="__RequestVerificationToken"]').val() ||
               $('meta[name="csrf-token"]').attr('content') || '';
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
