@{
    ViewData["Title"] = "My Properties";
}

<style>
.props-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
}
.props-search-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.props-search-wrap { position: relative; width: 240px; }
.props-search-wrap i { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--text-tertiary); font-size: 14px; pointer-events: none; }
.props-search-wrap input { width: 100%; padding: 8px 12px 8px 34px; border: 1.5px solid var(--border-strong); border-radius: var(--radius-md); background: var(--bg-surface); color: var(--text-primary); font-size: 13.5px; outline: none; transition: var(--transition-base); font-family: inherit; }
.props-search-wrap input:focus { border-color: var(--ds-navy-600); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
.filter-btn { padding: 7px 13px; border: 1.5px solid var(--border-strong); border-radius: var(--radius-md); background: var(--bg-surface); color: var(--text-secondary); font-size: 13px; font-weight: 500; cursor: pointer; transition: var(--transition-base); display: flex; align-items: center; gap: 6px; }
.filter-btn:hover, .filter-btn.active { background: var(--bg-surface-2); color: var(--text-primary); border-color: var(--ds-navy-600); }
.props-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 16px; }

/* Property Card */
.prop-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-xl); padding: 20px; box-shadow: var(--shadow-sm); cursor: pointer; transition: var(--transition-spring); text-decoration: none; display: block; color: inherit; }
.prop-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: var(--ds-navy-200); color: inherit; text-decoration: none; }
.prop-card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 14px; gap: 8px; }
.prop-type-icon { width: 44px; height: 44px; border-radius: var(--radius-lg); background: var(--ds-navy-50); border: 1px solid var(--ds-navy-100); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
.prop-card-menu { width: 28px; height: 28px; border-radius: var(--radius-md); border: none; background: transparent; color: var(--text-tertiary); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: var(--transition-base); font-size: 15px; }
.prop-card-menu:hover { background: var(--bg-surface-2); color: var(--text-primary); }
.prop-address { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; line-height: 1.3; }
.prop-city { font-size: 12.5px; color: var(--text-tertiary); margin-bottom: 14px; }
.prop-meta { display: flex; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
.prop-meta-item { display: flex; align-items: center; gap: 5px; font-size: 12.5px; color: var(--text-secondary); }
.prop-meta-item i { color: var(--text-tertiary); font-size: 13px; }
.prop-platforms { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 14px; }
.prop-card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 12px; border-top: 1px solid var(--border); }
.prop-gen-count { font-size: 12px; color: var(--text-tertiary); display: flex; align-items: center; gap: 4px; }

/* Add card */
.prop-card-add { border: 2px dashed var(--border-strong); border-radius: var(--radius-xl); padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; cursor: pointer; transition: var(--transition-base); text-decoration: none; min-height: 190px; background: transparent; }
.prop-card-add:hover { border-color: var(--ds-navy-600); background: var(--ds-navy-50); color: inherit; text-decoration: none; }
.prop-add-icon { width: 48px; height: 48px; border-radius: 50%; background: var(--bg-surface-2); display: flex; align-items: center; justify-content: center; font-size: 22px; color: var(--text-tertiary); transition: var(--transition-base); }
.prop-card-add:hover .prop-add-icon { background: var(--ds-navy-100); color: var(--ds-navy-700); }

/* Context menu */
#propContextMenu { position: fixed; z-index: 1000; display: none; min-width: 160px; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--bg-surface); padding: 4px; box-shadow: var(--shadow-lg); }
#propContextMenu a { font-size: 13px; padding: 8px 14px; display: flex; align-items: center; gap: 8px; color: var(--text-primary); text-decoration: none; border-radius: var(--radius-md); }
#propContextMenu a:hover { background: var(--bg-surface-2); }
#propContextMenu .ctx-divider { height: 1px; background: var(--border); margin: 4px 0; }
</style>

@Html.AntiForgeryToken()

<div class="props-header">
    <div>
        <h1 style="font-size:20px;font-weight:700;margin:0 0 2px">My Properties</h1>
        <p style="font-size:13px;color:var(--text-tertiary);margin:0" id="propCount">Loading…</p>
    </div>
    <div class="props-search-row">
        <div class="props-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" placeholder="Search properties…" />
        </div>
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="active">Active</button>
        <button class="filter-btn" data-filter="vacant">Vacant</button>
        <a href="/Property/Create" class="btn-ds-primary ms-2" id="btnAddProperty">
            <i class="bi bi-plus-lg"></i>Add Property
        </a>
    </div>
</div>

<div class="props-grid" id="propsGrid">
    @for (int i = 0; i < 3; i++)
    {
        <div class="prop-card" style="pointer-events:none">
            <div class="skeleton" style="width:44px;height:44px;border-radius:12px;margin-bottom:14px"></div>
            <div class="skeleton" style="height:14px;width:80%;margin-bottom:8px"></div>
            <div class="skeleton" style="height:12px;width:55%;margin-bottom:20px"></div>
            <div class="skeleton" style="height:12px;width:65%"></div>
        </div>
    }
</div>

<div id="propContextMenu">
    <a id="ctxGenerate" href="#"><i class="bi bi-stars"></i> Generate Listing</a>
    <a id="ctxEdit" href="#"><i class="bi bi-pencil"></i> Edit</a>
    <a id="ctxDuplicate" href="#"><i class="bi bi-copy"></i> Duplicate</a>
    <div class="ctx-divider"></div>
    <a id="ctxArchive" href="#" style="color:var(--ds-error)"><i class="bi bi-archive"></i> Archive</a>
</div>

@section Scripts {
<script>
var allProps = [];
var activeFilter = 'all';
var currentPropId = null;
var propertyMax = null; // null = unlimited
var typeIcons = { 'House':'🏠','Apartment':'🏢','Condo':'🏙️','Townhouse':'🏘️','Studio':'🛏️','Other':'🏗️' };

// Load tier/limit info
$.ajax({
    url: '/api/billing/status', method: 'GET',
    success: function(s) {
        propertyMax = s.propertyMax || null;
        updateAddButton();
    }
});

function statusPill(s) {
    var m = {0:['Active','ds-pill-active'],1:['Vacant','ds-pill-vacant'],2:['Archived','ds-pill-archived']};
    var d = m[s] || ['Unknown','ds-pill-archived'];
    return '<span class="ds-pill '+d[1]+'">'+d[0]+'</span>';
}

function platformTags(json) {
    try {
        return (JSON.parse(json||'[]')).map(function(p){
            return '<span class="ds-tag-'+p+'">'+{ltr:'LTR',str:'STR',social:'Social'}[p]+'</span>';
        }).join('');
    } catch(e){ return ''; }
}

function renderCard(p) {
    var icon = typeIcons[p.propertyType]||'🏠';
    return '<a href="/Property/Detail/'+p.id+'" class="prop-card">'+
        '<div class="prop-card-header">'+
            '<div class="prop-type-icon">'+icon+'</div>'+
            statusPill(p.status)+
            '<button class="prop-card-menu" onclick="openMenu(event,this)" data-id="'+p.id+'"><i class="bi bi-three-dots"></i></button>'+
        '</div>'+
        '<div class="prop-address">'+p.address+'</div>'+
        '<div class="prop-city">'+p.city+', '+p.state+' '+p.zip+'</div>'+
        '<div class="prop-meta">'+
            '<span class="prop-meta-item"><i class="bi bi-door-open"></i>'+p.bedrooms+' bd</span>'+
            '<span class="prop-meta-item"><i class="bi bi-droplet"></i>'+p.bathrooms+' ba</span>'+
            (p.squareFootage?'<span class="prop-meta-item"><i class="bi bi-arrows-angle-expand"></i>'+p.squareFootage+' sqft</span>':'')+
            (p.monthlyRent?'<span class="prop-meta-item"><i class="bi bi-currency-dollar"></i>'+Number(p.monthlyRent).toLocaleString()+'/mo</span>':'')+
        '</div>'+
        '<div class="prop-platforms">'+platformTags(p.platformsJson)+'</div>'+
        '<div class="prop-card-footer">'+
            '<span class="prop-gen-count"><i class="bi bi-file-text"></i>'+(p.generationCount||0)+' generations</span>'+
            '<span style="font-size:12px;color:var(--ds-navy-600);font-weight:600">Generate <i class="bi bi-arrow-right"></i></span>'+
        '</div>'+
    '</a>';
}

function atLimit() {
    return propertyMax !== null && allProps.length >= propertyMax;
}

function updateAddButton() {
    if (atLimit()) {
        $('#btnAddProperty').replaceWith(
            '<span class="btn-ds-primary ms-2 disabled" style="opacity:.5;cursor:not-allowed" id="btnAddProperty">'+
                '<i class="bi bi-plus-lg"></i>Add Property'+
                '<span style="font-size:11px;margin-left:6px;opacity:.8">('+allProps.length+'/'+propertyMax+')</span>'+
            '</span>'
        );
    } else {
        var el = $('#btnAddProperty');
        if (el.is('span')) {
            el.replaceWith('<a href="/Property/Create" class="btn-ds-primary ms-2" id="btnAddProperty"><i class="bi bi-plus-lg"></i>Add Property</a>');
        }
    }
}

function renderGrid(props) {
    var q = $('#searchInput').val().toLowerCase();
    var filtered = props.filter(function(p){
        if (p.isArchived) return false;
        if (activeFilter==='active' && p.status!==0) return false;
        if (activeFilter==='vacant' && p.status!==1) return false;
        if (q && !(p.address+' '+p.city+' '+p.state).toLowerCase().includes(q)) return false;
        return true;
    });
    var html = filtered.map(renderCard).join('');
    if (!atLimit()) {
        html += '<a href="/Property/Create" class="prop-card-add">'+
            '<div class="prop-add-icon"><i class="bi bi-plus-lg"></i></div>'+
            '<span style="font-size:13.5px;font-weight:600;color:var(--text-secondary)">Add Property</span>'+
            '<span style="font-size:12px;color:var(--text-tertiary)">Click to get started</span>'+
        '</a>';
    } else {
        html += '<div class="prop-card-add" style="cursor:default;opacity:.6">'+
            '<div class="prop-add-icon"><i class="bi bi-lock-fill"></i></div>'+
            '<span style="font-size:13.5px;font-weight:600;color:var(--text-secondary)">Property limit reached</span>'+
            '<a href="/Billing" style="font-size:12px;color:var(--ds-navy-600);font-weight:600">Upgrade to add more</a>'+
        '</div>';
    }
    $('#propsGrid').html(html);
    $('#propCount').text(filtered.length+' propert'+(filtered.length===1?'y':'ies'));
    updateAddButton();
}

function loadProps() {
    $.ajax({
        url: '/api/properties', method: 'GET',
        success: function(data){ allProps=data; renderGrid(allProps); },
        error: function(){
            $('#propsGrid').html('<div class="ds-empty"><div class="ds-empty-icon"><i class="bi bi-buildings"></i></div><p style="font-size:15px;font-weight:600;color:var(--text-primary);margin-bottom:4px">No properties yet</p><p style="font-size:13px">Add your first rental property to generate listings.</p><a href="/Property/Create" class="btn-ds-primary mt-2"><i class="bi bi-plus-lg"></i>Add Property</a></div>');
            $('#propCount').text('0 properties');
        }
    });
}

$('.filter-btn').on('click', function(){
    activeFilter=$(this).data('filter');
    $('.filter-btn').removeClass('active');
    $(this).addClass('active');
    renderGrid(allProps);
});

var st;
$('#searchInput').on('input', function(){ clearTimeout(st); st=setTimeout(function(){ renderGrid(allProps); },220); });

function openMenu(e, btn) {
    e.preventDefault(); e.stopPropagation();
    currentPropId = $(btn).data('id');
    var r = btn.getBoundingClientRect();
    $('#propContextMenu').css({top:(r.bottom+4)+'px',left:Math.max(10,r.left-120)+'px'}).show();
    $('#ctxEdit').attr('href','/Property/Edit/'+currentPropId);
    $('#ctxGenerate').attr('href','/Property/Detail/'+currentPropId);
}

$('#ctxDuplicate').on('click', function(e){
    e.preventDefault();
    if (!currentPropId) return;
    $.ajax({
        url:'/api/properties/'+currentPropId+'/duplicate', method:'POST',
        headers:{'RequestVerificationToken':$('input[name="__RequestVerificationToken"]').val()},
        success:function(res){ toastr.success('Property duplicated.'); loadProps(); },
        error:function(xhr){ toastr.error(xhr.responseJSON?.message || 'Failed to duplicate.'); }
    });
    $('#propContextMenu').hide();
});

$('#ctxArchive').on('click', function(e){
    e.preventDefault();
    if (!currentPropId||!confirm('Archive this property?')) return;
    $.ajax({
        url:'/api/properties/'+currentPropId+'/archive', method:'POST',
        headers:{'RequestVerificationToken':$('input[name="__RequestVerificationToken"]').val()},
        success:function(){ toastr.success('Property archived.'); loadProps(); },
        error:function(){ toastr.error('Failed to archive.'); }
    });
    $('#propContextMenu').hide();
});

$(document).on('click', function(e){
    if (!$(e.target).closest('#propContextMenu,.prop-card-menu').length) $('#propContextMenu').hide();
});

loadProps();
</script>
}
