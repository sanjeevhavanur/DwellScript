@{
    ViewData["Title"] = "Terms of Service";
    Layout = "_AuthLayout";
    var returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "";
}

<style>
.terms-accept-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-page);
    padding: 32px 16px;
}

.terms-accept-card {
    width: 100%;
    max-width: 640px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
}

.terms-accept-header {
    background: var(--ds-navy-900);
    background-image: radial-gradient(ellipse at 80% 20%, rgba(249,115,22,.15) 0%, transparent 50%);
    padding: 28px 32px;
    display: flex;
    align-items: center;
    gap: 14px;
}

.terms-accept-logo-mark {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--ds-warm-500), var(--ds-warm-600));
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
}

.terms-accept-header-text h1 {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 2px;
}

.terms-accept-header-text p {
    font-size: 13px;
    color: rgba(255,255,255,.55);
    margin: 0;
}

.terms-accept-body {
    padding: 28px 32px;
}

.terms-notice {
    background: rgba(234, 88, 12, 0.07);
    border: 1px solid rgba(234, 88, 12, 0.2);
    border-radius: var(--radius-lg);
    padding: 14px 16px;
    margin-bottom: 24px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
}

.terms-notice i {
    color: var(--ds-warm-500);
    font-size: 16px;
    margin-top: 1px;
    flex-shrink: 0;
}

.terms-notice p {
    margin: 0;
    font-size: 13.5px;
    color: var(--text-primary);
    line-height: 1.6;
}

.terms-scroll-box {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    height: 240px;
    overflow-y: auto;
    padding: 16px 18px;
    margin-bottom: 20px;
    background: var(--bg-surface-2);
    font-size: 13px;
    line-height: 1.7;
    color: var(--text-secondary);
    scroll-behavior: smooth;
}

.terms-scroll-box h3 {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 16px 0 6px;
}

.terms-scroll-box h3:first-child { margin-top: 0; }

.terms-scroll-box p { margin: 0 0 10px; }

.terms-scroll-box ul {
    padding-left: 18px;
    margin: 0 0 10px;
}

.terms-scroll-box li { margin-bottom: 3px; }

.terms-scroll-box .highlight-block {
    background: rgba(234,88,12,.08);
    border-left: 3px solid var(--ds-warm-500);
    padding: 10px 12px;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    margin: 10px 0;
    font-weight: 600;
    color: var(--text-primary);
}

.terms-read-full {
    display: block;
    text-align: center;
    font-size: 12px;
    color: var(--text-tertiary);
    margin-bottom: 20px;
}

.terms-read-full a {
    color: var(--ds-navy-500);
    text-decoration: none;
}

.terms-read-full a:hover { text-decoration: underline; }

.terms-agree-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 24px;
    padding: 16px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: var(--transition-base);
}

.terms-agree-row:hover { border-color: var(--ds-navy-400); background: var(--bg-surface-2); }
.terms-agree-row.checked { border-color: var(--ds-warm-500); background: rgba(234,88,12,.04); }

.terms-agree-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 1px;
    flex-shrink: 0;
    cursor: pointer;
    accent-color: var(--ds-warm-500);
}

.terms-agree-label {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-primary);
    cursor: pointer;
    user-select: none;
}

.terms-agree-label a {
    color: var(--ds-navy-500);
    font-weight: 600;
    text-decoration: none;
}

.terms-agree-label a:hover { text-decoration: underline; }

.btn-accept {
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, var(--ds-warm-500), var(--ds-warm-600));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition-spring);
    box-shadow: var(--shadow-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn-accept:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(234,88,12,.35);
}

.btn-accept:disabled {
    opacity: .45;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.terms-error {
    background: rgba(239,68,68,.08);
    border: 1px solid rgba(239,68,68,.25);
    border-radius: var(--radius-md);
    padding: 10px 14px;
    font-size: 13px;
    color: #dc2626;
    margin-bottom: 16px;
    display: none;
}

.terms-error.visible { display: block; }
</style>

<div class="terms-accept-shell">
    <div class="terms-accept-card">

        <div class="terms-accept-header">
            <div class="terms-accept-logo-mark">D</div>
            <div class="terms-accept-header-text">
                <h1>DwellScript Terms of Service</h1>
                <p>Please review and accept before continuing</p>
            </div>
        </div>

        <div class="terms-accept-body">

            <div class="terms-notice">
                <i class="bi bi-shield-lock-fill"></i>
                <p>We've updated our Terms of Service. You must review and accept them to continue using DwellScript. This is required for all users.</p>
            </div>

            <!-- Scrollable summary -->
            <div class="terms-scroll-box" id="termsSummary">
                <h3>1. What You're Agreeing To</h3>
                <p>These Terms form a legally binding agreement between you and DwellScript ("DwellScript"). By accepting, you agree to use the Service only for lawful purposes and in accordance with these Terms.</p>

                <h3>2. Eligibility</h3>
                <p>You must be at least <strong>18 years old</strong> and legally authorized to enter into contracts. The Service is intended for business use by landlords and property managers.</p>

                <h3>3. Subscriptions & Payment</h3>
                <p>Paid subscriptions are billed monthly or annually via Stripe and renew automatically. Prices may change with 30 days' notice.</p>

                <h3>4. No Refund Policy</h3>
                <div class="highlight-block">All subscription fees are non-refundable. Once a payment is processed, no refunds, credits, or pro-rated amounts will be issued for any reason, including early cancellation or plan downgrade.</div>

                <h3>5. Cancellation</h3>
                <p>You may cancel at any time. Your access continues through the end of the current paid period. No refund is issued for unused time.</p>

                <h3>6. AI-Generated Content</h3>
                <p>AI-generated listing copy may contain inaccuracies. You are solely responsible for reviewing all content before publishing. DwellScript does not guarantee any business results.</p>

                <h3>7. Fair Housing Compliance</h3>
                <div class="highlight-block">DwellScript provides automated Fair Housing Act filtering as a tool, not a guarantee. You remain solely and exclusively responsible for ensuring your published listings comply with all applicable federal, state, and local fair housing laws.</div>

                <h3>8. Data Retention</h3>
                <p>After account cancellation or termination, your data is retained for 90 days and then permanently deleted.</p>

                <h3>9. Dispute Resolution</h3>
                <p>Disputes are resolved by binding individual arbitration under JAMS rules. Class action lawsuits and jury trials are waived. You have 30 days from account creation to opt out of arbitration.</p>

                <h3>10. Limitation of Liability</h3>
                <p>DwellScript's total liability to you is capped at the greater of amounts paid in the last 12 months or $100. We are not liable for indirect, consequential, or punitive damages.</p>

                <h3>11. Governing Law</h3>
                <p>These Terms are governed by the laws of the Commonwealth of Virginia.</p>
            </div>

            <span class="terms-read-full">
                <a href="/Home/Terms" target="_blank">Read the full Terms of Service &rarr;</a>
            </span>

            <form method="post" action="/Terms/Accept" id="termsForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="terms-error" id="termsError">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    You must check the box above to continue.
                </div>

                <div class="terms-agree-row" id="agreeRow" onclick="toggleCheck()">
                    <input type="checkbox" name="agreed" id="agreedCheck" value="true" />
                    <label class="terms-agree-label" for="agreedCheck">
                        I have read and agree to the <a href="/Home/Terms" target="_blank" onclick="event.stopPropagation()">Terms of Service</a>,
                        including the <strong>no-refund policy</strong>, the <strong>binding arbitration agreement</strong>, and the
                        <strong>class action waiver</strong>. I confirm that I am at least 18 years of age and am authorized to use this Service.
                    </label>
                </div>

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="terms-error visible">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        You must agree to the Terms of Service to continue.
                    </div>
                }

                <button type="submit" class="btn-accept" id="acceptBtn" disabled>
                    <i class="bi bi-check-circle-fill"></i>
                    I Agree — Continue to DwellScript
                </button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleCheck() {
        var cb = document.getElementById('agreedCheck');
        cb.checked = !cb.checked;
        updateState();
    }

    // Prevent double-toggle when clicking the checkbox directly
    document.getElementById('agreedCheck').addEventListener('click', function (e) {
        e.stopPropagation();
        updateState();
    });

    function updateState() {
        var checked = document.getElementById('agreedCheck').checked;
        var row = document.getElementById('agreeRow');
        var btn = document.getElementById('acceptBtn');
        var err = document.getElementById('termsError');

        if (checked) {
            row.classList.add('checked');
            btn.disabled = false;
            err.classList.remove('visible');
        } else {
            row.classList.remove('checked');
            btn.disabled = true;
        }
    }

    document.getElementById('termsForm').addEventListener('submit', function (e) {
        if (!document.getElementById('agreedCheck').checked) {
            e.preventDefault();
            document.getElementById('termsError').classList.add('visible');
        }
    });
</script>
}
